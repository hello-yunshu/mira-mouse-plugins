{
  "schemaVersion": 1,
  "workflows": {
    "protocol-a-direct-read": {
      "transport": "protocol-a",
      "steps": [
        { "command": "battery", "parser": "battery", "output": "battery" },
        { "command": "dpi", "parser": "dpi", "output": "dpi" },
        { "command": "settings", "parser": "settings", "output": "settings" },
        { "command": "lighting", "parser": "lighting", "output": "mouseEffect" },
        { "command": "fps", "parser": "fps", "output": "fps" },
        { "command": "dpi-button", "parser": "dpi-button", "output": "dpiButton" },
        { "command": "firmware-usb", "parser": "firmware", "output": "firmwareUsb" },
        { "command": "firmware-soc", "parser": "firmware", "output": "firmwareSoc" },
        { "command": "button-mappings", "parser": "button-mappings", "output": "buttonMappings", "params": { "layer": 0 } }
      ]
    },
    "protocol-a-receiver-read": {
      "transport": "protocol-a-receiver",
      "steps": [
        { "command": "receiver-poll", "parser": "receiver-status", "output": "receiverIdle", "transport": "protocol-a" },
        { "command": "receiver-firmware-usb", "parser": "firmware", "output": "receiverFirmwareUsb", "transport": "protocol-a" },
        { "command": "receiver-firmware-soc", "parser": "receiver-firmware-soc", "output": "receiverFirmwareSoc", "transport": "protocol-a" },
        { "command": "receiver-firmware-led", "parser": "firmware", "output": "receiverFirmwareLed", "transport": "protocol-a" },
        { "command": "battery", "parser": "battery", "output": "battery", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "dpi", "parser": "dpi", "output": "dpi", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "settings", "parser": "settings", "output": "settings", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "lighting", "parser": "lighting", "output": "receiverLighting", "transport": "protocol-a" },
        { "command": "fps", "parser": "fps", "output": "fps", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "dpi-button", "parser": "dpi-button", "output": "dpiButton", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "firmware-usb", "parser": "firmware", "output": "firmwareUsb", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "firmware-soc", "parser": "firmware", "output": "firmwareSoc", "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] },
        { "command": "button-mappings", "parser": "button-mappings", "output": "buttonMappings", "params": { "layer": 0 }, "skipIfZero": [{ "output": "receiverIdle", "field": "mouseOnline" }] }
      ]
    },
    "am35-direct-read": {
      "transport": "am35-direct",
      "steps": [
        { "command": "am35-battery", "parser": "am35-battery", "output": "battery" },
        { "command": "am35-dpi", "parser": "am35-dpi", "output": "dpi" },
        { "command": "am35-polling-rate", "parser": "am35-polling-rate", "output": "pollingRate" },
        { "command": "am35-sleep-time", "parser": "am35-sleep-time", "output": "sleepTime" },
        { "command": "am35-fps", "parser": "am35-fps", "output": "fps" },
        { "command": "am35-dpi-button", "parser": "am35-dpi-button", "output": "dpiButton" },
        { "command": "am35-rotation", "parser": "am35-rotation", "output": "rotation" },
        { "command": "am35-mouse-light-mode", "parser": "am35-mouse-light-mode", "output": "mouseLightMode" },
        { "command": "am35-mouse-light-color", "parser": "am35-mouse-light-color", "output": "mouseLightColor" },
        { "command": "am35-debounce", "parser": "am35-debounce", "output": "debounce" },
        { "command": "am35-lod", "parser": "am35-lod", "output": "lod" },
        { "command": "am35-motion-sync", "parser": "am35-motion-sync", "output": "motionSync" },
        { "command": "am35-angle-snapping", "parser": "am35-angle-snapping", "output": "angleSnap" },
        { "command": "am35-ripple-control", "parser": "am35-ripple-control", "output": "rippleControl" },
        { "command": "am35-profile", "parser": "am35-profile", "output": "profile" },
        { "command": "am35-firmware", "parser": "am35-firmware", "output": "firmware" }
      ]
    },
    "am35-receiver-read": {
      "transport": "am35-receiver",
      "steps": [
        { "command": "am35-battery", "parser": "am35-battery", "output": "battery" },
        { "command": "am35-receiver-battery", "parser": "am35-receiver-battery", "output": "receiverBattery", "transport": "am35-direct" },
        { "command": "am35-dpi", "parser": "am35-dpi", "output": "dpi" },
        { "command": "am35-polling-rate", "parser": "am35-polling-rate", "output": "pollingRate" },
        { "command": "am35-sleep-time", "parser": "am35-sleep-time", "output": "sleepTime" },
        { "command": "am35-fps", "parser": "am35-fps", "output": "fps" },
        { "command": "am35-dpi-button", "parser": "am35-dpi-button", "output": "dpiButton" },
        { "command": "am35-rotation", "parser": "am35-rotation", "output": "rotation" },
        { "command": "am35-mouse-light-mode", "parser": "am35-mouse-light-mode", "output": "mouseLightMode" },
        { "command": "am35-mouse-light-color", "parser": "am35-mouse-light-color", "output": "mouseLightColor" },
        { "command": "am35-receiver-light", "parser": "am35-receiver-light", "output": "receiverLight", "transport": "am35-direct" },
        { "command": "am35-debounce", "parser": "am35-debounce", "output": "debounce" },
        { "command": "am35-lod", "parser": "am35-lod", "output": "lod" },
        { "command": "am35-motion-sync", "parser": "am35-motion-sync", "output": "motionSync" },
        { "command": "am35-angle-snapping", "parser": "am35-angle-snapping", "output": "angleSnap" },
        { "command": "am35-ripple-control", "parser": "am35-ripple-control", "output": "rippleControl" },
        { "command": "am35-profile", "parser": "am35-profile", "output": "profile" },
        { "command": "am35-firmware", "parser": "am35-firmware", "output": "firmware" }
      ]
    }
  },
  "mutations": {
    "protocol-a-direct-set-dpi-stage": {
      "transport": "protocol-a",
      "inputs": { "stage": { "kind": "integer", "min": 1, "max": 8 } },
      "read": { "command": "dpi", "parser": "dpi" },
      "writeCommand": "dpi-stage-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "dpi", "parser": "dpi", "assertions": [{ "field": "currentStage", "param": "stage" }] }
    },
    "protocol-a-receiver-set-dpi-stage": {
      "transport": "protocol-a-receiver",
      "inputs": { "stage": { "kind": "integer", "min": 1, "max": 8 } },
      "read": { "command": "dpi", "parser": "dpi" },
      "writeCommand": "dpi-stage-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "dpi", "parser": "dpi", "assertions": [{ "field": "currentStage", "param": "stage" }] }
    },
    "protocol-a-direct-set-dpi-value": {
      "transport": "protocol-a",
      "inputs": { "stage": { "kind": "integer", "min": 1, "max": 8 }, "dpi": { "kind": "integer", "min": 50, "max": 30000, "step": 50 } },
      "read": { "command": "dpi", "parser": "dpi" },
      "writeCommand": "dpi-value-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "dpi", "parser": "dpi", "assertions": [{ "field": "dpiX", "param": "dpi", "indexParam": "stage", "indexBase": 1 }, { "field": "dpiY", "param": "dpi", "indexParam": "stage", "indexBase": 1 }] }
    },
    "protocol-a-receiver-set-dpi-value": {
      "transport": "protocol-a-receiver",
      "inputs": { "stage": { "kind": "integer", "min": 1, "max": 8 }, "dpi": { "kind": "integer", "min": 50, "max": 30000, "step": 50 } },
      "read": { "command": "dpi", "parser": "dpi" },
      "writeCommand": "dpi-value-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "dpi", "parser": "dpi", "assertions": [{ "field": "dpiX", "param": "dpi", "indexParam": "stage", "indexBase": 1 }, { "field": "dpiY", "param": "dpi", "indexParam": "stage", "indexBase": 1 }] }
    },
    "protocol-a-direct-set-polling-rate": {
      "transport": "protocol-a",
      "inputs": { "rate": { "kind": "integer", "allowed": [125, 250, 500, 1000, 2000, 4000, 8000] } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "polling-rate-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "pollingRate", "param": "rate" }] }
    },
    "protocol-a-receiver-set-polling-rate": {
      "transport": "protocol-a-receiver",
      "inputs": { "rate": { "kind": "integer", "allowed": [125, 250, 500, 1000, 2000, 4000, 8000] } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "polling-rate-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "pollingRate", "param": "rate" }] }
    },
    "protocol-a-direct-set-bluetooth-sleep-time": {
      "transport": "protocol-a",
      "inputs": { "seconds": { "kind": "integer", "min": 10, "max": 65535 } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "bluetooth-sleep-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "bluetoothSleepValue", "param": "seconds" }] }
    },
    "protocol-a-receiver-set-bluetooth-sleep-time": {
      "transport": "protocol-a-receiver",
      "inputs": { "seconds": { "kind": "integer", "min": 10, "max": 65535 } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "bluetooth-sleep-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "bluetoothSleepValue", "param": "seconds" }] }
    },
    "protocol-a-direct-set-wireless-sleep-time": {
      "transport": "protocol-a",
      "inputs": { "seconds": { "kind": "integer", "min": 10, "max": 65535 } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "wireless-sleep-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "wirelessSleepValue", "param": "seconds" }] }
    },
    "protocol-a-receiver-set-wireless-sleep-time": {
      "transport": "protocol-a-receiver",
      "inputs": { "seconds": { "kind": "integer", "min": 10, "max": 65535 } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "wireless-sleep-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "wirelessSleepValue", "param": "seconds" }] }
    },
    "protocol-a-direct-set-mouse-lighting": {
      "transport": "protocol-a",
      "inputs": { "color": { "kind": "color" }, "enabled": { "kind": "boolean" } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "mouse-lighting-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "mouseLightStartColor", "param": "color" }, { "field": "mouseLightEndColor", "param": "color" }, { "field": "mouseLightEnabled", "param": "enabled" }] }
    },
    "protocol-a-receiver-set-mouse-lighting": {
      "transport": "protocol-a-receiver",
      "inputs": { "color": { "kind": "color" }, "enabled": { "kind": "boolean" } },
      "read": { "command": "settings", "parser": "settings" },
      "writeCommand": "mouse-lighting-write",
      "preserveUnknown": true,
      "settleMs": 30,
      "verify": { "command": "settings", "parser": "settings", "assertions": [{ "field": "mouseLightStartColor", "param": "color" }, { "field": "mouseLightEndColor", "param": "color" }, { "field": "mouseLightEnabled", "param": "enabled" }] }
    },
    "protocol-a-receiver-set-receiver-lighting": {
      "transport": "protocol-a",
      "inputs": {
        "effect": { "kind": "integer", "min": 0, "max": 8 },
        "speed": { "kind": "integer", "min": 0, "max": 4 },
        "brightness": { "kind": "integer", "min": 0, "max": 4 },
        "option": { "kind": "integer", "min": 0, "max": 8 },
        "color": { "kind": "color" }
      },
      "read": { "command": "lighting", "parser": "lighting" },
      "writeCommand": "receiver-lighting-write",
      "preserveUnknown": false,
      "settleMs": 30,
      "verify": { "command": "lighting", "parser": "lighting", "assertions": [{ "field": "effect", "param": "effect" }, { "field": "speed", "param": "speed" }, { "field": "brightness", "param": "brightness" }, { "field": "option", "param": "option" }, { "field": "color", "param": "color" }] }
    },
    "am35-receiver-set-receiver-lighting": {
      "transport": "am35-receiver",
      "inputs": {
        "effect": { "kind": "integer", "min": 0, "max": 8 },
        "speed": { "kind": "integer", "min": 0, "max": 4 },
        "brightness": { "kind": "integer", "min": 0, "max": 4 },
        "option": { "kind": "integer", "min": 0, "max": 8 },
        "color": { "kind": "color" }
      },
      "read": { "command": "am35-receiver-light", "parser": "am35-receiver-light" },
      "writeCommand": "am35-receiver-light-write",
      "preserveUnknown": false,
      "settleMs": 30,
      "verify": { "command": "am35-receiver-light", "parser": "am35-receiver-light", "assertions": [{ "field": "type", "param": "effect" }, { "field": "speed", "param": "speed" }, { "field": "brightness", "param": "brightness" }] }
    },
    "am35-direct-set-profile": {
      "transport": "am35-direct",
      "inputs": { "profile": { "kind": "integer", "min": 1, "max": 8 } },
      "read": { "command": "am35-profile", "parser": "am35-profile" },
      "writeCommand": "am35-profile-write",
      "preserveUnknown": false,
      "settleMs": 30,
      "verify": { "command": "am35-profile", "parser": "am35-profile", "assertions": [{ "field": "profile", "param": "profile" }] }
    },
    "am35-receiver-set-profile": {
      "transport": "am35-receiver",
      "inputs": { "profile": { "kind": "integer", "min": 1, "max": 8 } },
      "read": { "command": "am35-profile", "parser": "am35-profile" },
      "writeCommand": "am35-profile-write",
      "preserveUnknown": false,
      "settleMs": 30,
      "verify": { "command": "am35-profile", "parser": "am35-profile", "assertions": [{ "field": "profile", "param": "profile" }] }
    }
  }
}
