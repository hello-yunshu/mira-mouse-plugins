{
  "schemaVersion": 1,
  "pluginId": "mira.amaster",
  "name": "AMaster Protocol A",
  "version": "1.6.2",
  "pluginApi": ">=1.0.0, <2.0.0",
  "publisherKeyId": null,
  "evidence": "hardware-verified",
  "permissions": [{ "kind": "hid", "report_types": ["feature", "input", "output"], "max_report_length": 64, "max_reports_per_second": 60 }],
  "capabilities": [
    { "id": "battery", "control": "ReadOnlyValue", "labelKey": "capability.battery", "readOnly": true, "placements": [{ "region": "hero", "order": 10, "span": 1, "icon": "battery" }], "metadata": { "fields": [{ "id": "value", "source": "battery", "editor": "static-readonly", "format": "percent", "labelKey": "capability.battery" }], "batteryHistory": { "validConnections": ["wireless", "bluetooth"] } } },
    { "id": "dpi", "control": "DpiStages", "labelKey": "capability.dpi", "readOnly": false, "placements": [{ "region": "control", "group": "performance", "order": 10, "span": 1, "icon": "gauge" }], "metadata": { "stageLayout": { "dotsSource": "state.dpiStages", "selectMutation": "set-dpi-stage", "setMutation": "set-dpi-value", "valueSource": "state.dpiStages", "range": { "min": 50, "max": 30000, "step": 50 }, "selectParam": "stage", "stageParam": "stage", "valueParam": "dpi" }, "stateMapping": { "dpiStages": "dpiStages" } } },
    { "id": "polling-rate", "control": "Select", "labelKey": "capability.polling-rate", "readOnly": false, "placements": [{ "region": "control", "group": "polling", "order": 20, "span": 1, "icon": "wave" }], "metadata": { "fields": [{ "id": "value", "source": "state.pollingRate", "mutation": "set-polling-rate", "param": "rate", "editor": "modal-select", "optionSource": "state.supportedPollingRates", "format": "hertz", "labelKey": "capability.polling-rate" }], "stateMapping": { "pollingRate": "pollingRateHz", "supportedPollingRates": "supportedPollingRatesHz" }, "summary": [{ "labelKey": "summary.motionSync", "source": "capabilities.settings.motionSync" }, { "labelKey": "summary.angleSnap", "source": "capabilities.settings.angleSnap" }, { "labelKey": "summary.liftCutOff", "source": "capabilities.settings.liftCutOff" }] } },
    { "id": "sleep-time", "control": "Number", "labelKey": "capability.sleep-time", "readOnly": false, "placements": [{ "region": "status", "order": 10, "span": 1, "icon": "timer" }], "metadata": { "fields": [{ "id": "bluetooth", "source": "capabilities.settings.bluetoothSleepValue", "mutation": "set-bluetooth-sleep-time", "param": "seconds", "editor": "modal-number", "format": "sleep", "range": { "min": 10, "max": 65535, "step": 10 }, "labelKey": "sleep.bluetooth", "editTitleKey": "dashboard.setSleepTitle", "editLabelKey": "dashboard.timeoutSeconds", "visibleWhen": { "path": "connection", "eq": "bluetooth" } }, { "id": "wireless", "source": "capabilities.settings.wirelessSleepValue", "mutation": "set-wireless-sleep-time", "param": "seconds", "editor": "modal-number", "format": "sleep", "range": { "min": 10, "max": 65535, "step": 10 }, "labelKey": "sleep.wireless", "editTitleKey": "dashboard.setSleepTitle", "editLabelKey": "dashboard.timeoutSeconds", "visibleWhen": { "path": "connection", "eq": "wireless" } }, { "id": "virtual", "source": "capabilities.settings.wirelessSleepValue", "mutation": "set-wireless-sleep-time", "param": "seconds", "editor": "modal-number", "format": "sleep", "range": { "min": 10, "max": 65535, "step": 10 }, "labelKey": "sleep.wireless", "editTitleKey": "dashboard.setSleepTitle", "editLabelKey": "dashboard.timeoutSeconds", "visibleWhen": { "path": "connection", "eq": "virtual" } }], "statusDisplay": { "valueSource": "capabilities.settings.wirelessSleepValue", "valueFormat": "sleep", "onClickField": "wireless" } } },
    { "id": "profile", "control": "ReadOnlyValue", "labelKey": "capability.profile", "readOnly": true, "placements": [{ "region": "status", "order": 20, "span": 1, "icon": "profile" }], "metadata": { "fields": [{ "id": "value", "source": "state.profile", "editor": "static-readonly", "labelKey": "capability.profile" }], "statusDisplay": { "valueSource": "state.profile" }, "stateMapping": { "profile": "profile" } } },
    { "id": "lighting", "control": "LightingZone", "labelKey": "capability.lighting", "readOnly": false, "placements": [{ "region": "control", "group": "lighting", "order": 30, "span": 1, "icon": "lightbulb" }, { "region": "status", "order": 30, "span": 1, "icon": "lightbulb" }], "metadata": { "accentSource": "capabilities.mouseLighting.color", "zones": [{ "id": "mouse", "labelKey": "lighting.mouse", "fields": [{ "id": "enabled", "source": "capabilities.settings.mouseLightEnabled", "mutation": "set-mouse-lighting", "param": "enabled", "editor": "inline-toggle", "switch": { "source": "capabilities.settings.mouseLightEnabled", "offValue": false }, "labelKey": "dashboard.status", "paramSources": { "color": "capabilities.mouseLighting.color", "enabled": "capabilities.settings.mouseLightEnabled" } }, { "id": "color", "source": "capabilities.mouseLighting.color", "mutation": "set-mouse-lighting", "param": "color", "editor": "modal-color", "format": "color", "labelKey": "receiverLighting.field.color", "editTitleKey": "dashboard.mouseLightColor", "paramSources": { "color": "capabilities.mouseLighting.color", "enabled": "capabilities.settings.mouseLightEnabled" } }] }, { "id": "receiver", "labelKey": "lighting.receiver", "visibleWhen": { "path": "capabilities.receiverLighting" }, "fields": [{ "id": "effect", "source": "capabilities.receiverLighting.effect", "mutation": "set-receiver-lighting", "param": "effect", "editor": "modal-select", "labelKey": "receiverLighting.field.effect", "editTitleKey": "dashboard.editReceiverLightingTitle", "labelSource": "capabilities.receiverLighting.effectName", "options": [{ "value": 0, "labelKey": "receiverLighting.effect.off" }, { "value": 1, "labelKey": "receiverLighting.effect.fixed" }, { "value": 2, "labelKey": "receiverLighting.effect.breathing" }, { "value": 3, "labelKey": "receiverLighting.effect.neon" }, { "value": 4, "labelKey": "receiverLighting.effect.wave" }, { "value": 5, "labelKey": "receiverLighting.effect.running" }, { "value": 6, "labelKey": "receiverLighting.effect.ring" }, { "value": 7, "labelKey": "receiverLighting.effect.buffer" }, { "value": 8, "labelKey": "receiverLighting.effect.chase" }], "paramSources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }, { "id": "option", "source": "capabilities.receiverLighting.option", "mutation": "set-receiver-lighting", "param": "option", "editor": "modal-select", "labelKey": "receiverLighting.field.option", "editTitleKey": "dashboard.editReceiverLightingTitle", "labelSource": "capabilities.receiverLighting.optionName", "options": [{ "value": 0, "labelKey": "receiverLighting.colorMode.red" }, { "value": 1, "labelKey": "receiverLighting.colorMode.orange" }, { "value": 2, "labelKey": "receiverLighting.colorMode.yellow" }, { "value": 3, "labelKey": "receiverLighting.colorMode.green" }, { "value": 4, "labelKey": "receiverLighting.colorMode.cyan" }, { "value": 5, "labelKey": "receiverLighting.colorMode.blue" }, { "value": 6, "labelKey": "receiverLighting.colorMode.purple" }, { "value": 7, "labelKey": "receiverLighting.colorMode.custom" }, { "value": 8, "labelKey": "receiverLighting.colorMode.colorful" }], "paramSources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }, { "id": "speed", "source": "capabilities.receiverLighting.speed", "mutation": "set-receiver-lighting", "param": "speed", "editor": "modal-select", "labelKey": "receiverLighting.field.speed", "editTitleKey": "dashboard.editReceiverLightingTitle", "labelSource": "capabilities.receiverLighting.speedLabel", "options": [{ "value": 0, "labelKey": "receiverLighting.speed.fastest" }, { "value": 1, "labelKey": "receiverLighting.speed.fast" }, { "value": 2, "labelKey": "receiverLighting.speed.medium" }, { "value": 3, "labelKey": "receiverLighting.speed.slow" }, { "value": 4, "labelKey": "receiverLighting.speed.slowest" }], "paramSources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }, { "id": "brightness", "source": "capabilities.receiverLighting.brightness", "mutation": "set-receiver-lighting", "param": "brightness", "editor": "modal-select", "labelKey": "receiverLighting.field.brightness", "editTitleKey": "dashboard.editReceiverLightingTitle", "labelSource": "capabilities.receiverLighting.brightnessLabel", "options": [{ "value": 0, "labelKey": "receiverLighting.brightness.dimmest" }, { "value": 1, "labelKey": "receiverLighting.brightness.dark" }, { "value": 2, "labelKey": "receiverLighting.brightness.medium" }, { "value": 3, "labelKey": "receiverLighting.brightness.bright" }, { "value": 4, "labelKey": "receiverLighting.brightness.brightest" }], "paramSources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }, { "id": "color", "source": "capabilities.receiverLighting.color", "mutation": "set-receiver-lighting", "param": "color", "editor": "modal-color", "format": "color", "labelKey": "receiverLighting.field.color", "editTitleKey": "dashboard.editReceiverLightingTitle", "paramSources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }] }], "statusDisplay": { "labelKey": "capability.lighting", "valueSource": "capabilities.settings.mouseLightEnabled", "valueOptions": [{ "value": false, "labelKey": "lighting.off" }, { "value": true, "labelKey": "lighting.on" }], "onClickField": "enabled" } } },
    { "id": "firmware", "control": "ReadOnlyValue", "labelKey": "capability.firmware", "readOnly": true, "placements": [{ "region": "details", "order": 10, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.firmwareUsb", "editor": "static-readonly", "labelKey": "capability.firmware" }] } },
    { "id": "device-settings", "control": "ReadOnlyValue", "labelKey": "plugin.label.capability.device-settings", "readOnly": true, "placements": [{ "region": "details", "order": 20, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.settings", "editor": "static-readonly", "labelKey": "plugin.label.capability.device-settings" }] } },
    { "id": "receiver-status", "control": "ReadOnlyValue", "labelKey": "plugin.label.capability.receiver-status", "readOnly": true, "placements": [{ "region": "details", "order": 30, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.receiverLighting", "editor": "static-readonly", "labelKey": "plugin.label.capability.receiver-status" }] } },
    { "id": "button-mappings", "control": "ReadOnlyValue", "labelKey": "plugin.label.capability.button-mappings", "readOnly": true, "placements": [{ "region": "details", "order": 40, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.buttonMappings", "editor": "static-readonly", "labelKey": "plugin.label.capability.button-mappings" }] } }
  ],
  "writesEnabled": true,
  "exportableFields": [
    { "id": "current-dpi-stage", "exportKey": "currentDpiStage", "kind": "number", "mutation": "set-dpi-stage", "param": "stage", "source": "capabilities.dpi.currentStage" },
    { "id": "polling-rate", "exportKey": "pollingRate", "kind": "number", "mutation": "set-polling-rate", "param": "rate", "source": "capabilities.settings.pollingRate" },
    { "id": "bluetooth-sleep", "exportKey": "bluetoothSleepSeconds", "kind": "number", "mutation": "set-bluetooth-sleep-time", "param": "seconds", "source": "capabilities.settings.bluetoothSleepValue" },
    { "id": "wireless-sleep", "exportKey": "wirelessSleepSeconds", "kind": "number", "mutation": "set-wireless-sleep-time", "param": "seconds", "source": "capabilities.settings.wirelessSleepValue" },
    { "id": "mouse-lighting", "exportKey": "mouseLighting", "kind": "object", "mutation": "set-mouse-lighting", "sources": { "color": "capabilities.mouseLighting.color", "enabled": "capabilities.settings.mouseLightEnabled" } },
    { "id": "receiver-lighting", "exportKey": "receiverLighting", "kind": "object", "mutation": "set-receiver-lighting", "sources": { "effect": "capabilities.receiverLighting.effect", "speed": "capabilities.receiverLighting.speed", "brightness": "capabilities.receiverLighting.brightness", "option": "capabilities.receiverLighting.option", "color": "capabilities.receiverLighting.color" } }
  ]
}
