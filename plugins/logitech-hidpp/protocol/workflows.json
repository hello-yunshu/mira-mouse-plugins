  "mutations": {
    "hidpp2-device-set-control-mode": {
      "transport": "hidpp2-long",
      "skipIfZero": [{ "output": "featureIndexOnboardProfiles", "field": "featureIndex" }],
      "inputs": {
        "mode": { "kind": "integer", "min": 1, "max": 2, "step": 1, "allowed": [1, 2] }
      },
      "read": {
        "command": "onboard-get-mode",
        "parser": "onboard-get-mode",
        "params": {
          "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "featureIndexOnboardProfiles", "field": "featureIndex" }
        }
      },
      "writeCommand": "onboard-set-mode",
      "writeParams": {
        "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
        "featureIndex": { "fromOutput": "featureIndexOnboardProfiles", "field": "featureIndex" }
      },
      "preserveUnknown": false,
      "settleMs": 80,
      "verify": {
        "command": "onboard-get-mode",
        "parser": "onboard-get-mode",
        "params": {
          "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "featureIndexOnboardProfiles", "field": "featureIndex" }
        },
        "assertions": [
          { "field": "mode", "param": "mode" }
        ]
      }
    },
    "hidpp2-device-set-dpi-value": {
      "transport": "hidpp2-long",
      "skipIfZero": [{"output": "featureIndexDpi", "field": "featureIndex"}],
      "inputs": {
        "stage": { "kind": "integer", "min": 1, "max": 8, "step": 1 },
        "dpi": { "kind": "integer", "min": 50, "max": 30000, "step": 50 }
      },
      "read": {
        "command": "dpi-get-current",
        "parser": "dpi-get-current",
        "params": {
          "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "featureIndexDpi", "field": "featureIndex" }
        }
      },
      "writeCommand": "dpi-set",
      "writeParams": {
        "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
        "featureIndex": { "fromOutput": "featureIndexDpi", "field": "featureIndex" }
      },
      "memory": {
        "readWorkflow": "hidpp2-device-onboard-read",
        "availableWhen": { "output": "featureIndexOnboardProfiles", "field": "featureIndex" },
        "enabledWhen": { "output": "onboardMode", "field": "mode", "eq": 1 },
        "size": { "output": "onboardDescription", "field": "sectorSize" },
        "chunkOutputPrefix": "onboardProfileChunk",
        "chunkField": "bytes",
        "chunkSize": 16,
        "checksum": "crc-ccitt-false",
        "patches": [
          { "offset": 3, "param": "dpi", "encoding": "le-u16", "indexedBy": "dpiIndex", "indexBase": 0, "stride": 2 }
        ],
        "patchParams": {
          "dpiIndex": { "fromOutput": "onboardCurrentDpiIndex", "field": "index" }
        },
        "transport": "hidpp2-long",
        "startCommand": "onboard-memory-write-start",
        "chunkCommand": "onboard-memory-write-chunk",
        "endTransport": "hidpp2-short",
        "endCommand": "onboard-memory-write-end",
        "endExpectResponse": false,
        "contextParams": {
          "deviceIndex": { "fromOutput": "onboardFeature", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "onboardFeature", "field": "featureIndex" },
          "sector": { "fromOutput": "onboardCurrentProfile", "field": "sector" }
        }
      },
      "preserveUnknown": false,
      "settleMs": 50,
      "verify": {
        "command": "dpi-get-current",
        "parser": "dpi-get-current",
        "params": {
          "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "featureIndexDpi", "field": "featureIndex" }
        },
        "assertions": [
          { "field": "dpiValue", "param": "dpi" }
        ]
      }
    },
    "hidpp2-device-set-polling-rate": {
      "transport": "hidpp2-long",
      "skipIfZero": [{"output": "featureIndexReportRate", "field": "featureIndex"}],
      "inputs": {
        "rate": { "kind": "integer", "min": 125, "max": 1000, "step": 125, "allowed": [125, 250, 500, 1000] }
      },
      "read": {
        "command": "report-rate-get",
        "parser": "report-rate-get",
        "params": {
          "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
          "featureIndex": { "fromOutput": "featureIndexReportRate", "field": "featureIndex" }
        }
      },
      "writeCommand": "report-rate-set",
      "writeParams": {
        "deviceIndex": { "fromOutput": "device", "field": "deviceIndex" },
        "featureIndex": { "fromOutput": "featureIndexReportRate", "field": "featureIndex" }
      },
      "memory": {
        "readWorkflow": "hidpp2-device-onboard-read",
        "availableWhen": { "output": "featureIndexOnboardProfiles", "field": "featureIndex" },
        "enabledWhen": { "output": "onboardMode", "field": "mode", "eq": 1 },
        "size": { "output": "onboardDescription", "field": "sectorSize" },
        "chunkOutputPrefix": "onboardProfileChunk",
        "chunkField": "bytes",
        "chunkSize": 16,
        "checksum": "crc-ccitt-false",
        "patches": [
