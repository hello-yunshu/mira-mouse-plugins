{
  "schemaVersion": 1,
  "pluginId": "mira.logitech-hidpp",
  "name": "Logitech HID++",
  "version": "0.8.0",
  "pluginApi": ">=1.0.0, <2.0.0",
  "publisherKeyId": null,
  "evidence": "hardware-verified",
  "permissions": [{ "kind": "hid", "report_types": ["feature", "input", "output"], "max_report_length": 20, "max_reports_per_second": 60 }],
  "capabilities": [
    { "id": "battery", "control": "ReadOnlyValue", "labelKey": "capability.battery", "readOnly": true, "placements": [{ "region": "hero", "order": 10, "span": 1, "icon": "battery" }], "metadata": { "fields": [{ "id": "value", "source": "battery", "editor": "static-readonly", "format": "percent", "labelKey": "capability.battery" }], "batteryHistory": { "validConnections": ["wireless"] } } },
    { "id": "control-mode", "control": "Segmented", "labelKey": "plugin.label.capability.control-mode", "readOnly": false, "placements": [{ "region": "control", "group": "configuration", "order": 5, "span": 1, "icon": "profile" }, { "region": "status", "order": 10, "span": 1, "icon": "profile" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.controlMode.mode", "mutation": "set-control-mode", "param": "mode", "editor": "inline-segmented", "labelKey": "plugin.label.capability.control-mode", "options": [{ "value": 1, "labelKey": "controlMode.onboard" }, { "value": 2, "labelKey": "controlMode.software" }] }], "statusDisplay": { "valueSource": "capabilities.controlMode.mode", "valueOptions": [{ "value": 1, "labelKey": "controlMode.onboard" }, { "value": 2, "labelKey": "controlMode.software" }], "onClickField": "value" } } },
    { "id": "profile-mgmt-current", "control": "Number", "labelKey": "plugin.label.capability.profile-mgmt-current", "readOnly": false, "placements": [{ "region": "control", "group": "configuration", "order": 6, "span": 1, "icon": "profile" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.profileMgmtCurrent.profileIndex", "mutation": "set-profile-mgmt-current", "param": "profileIndex", "editor": "modal-number", "range": { "min": 0, "max": 15, "step": 1 }, "labelKey": "plugin.label.capability.profile-mgmt-current" }] } },
    { "id": "dpi", "control": "DpiStages", "labelKey": "capability.dpi", "readOnly": false, "placements": [{ "region": "control", "group": "performance", "order": 10, "span": 1, "icon": "gauge" }], "metadata": { "stageLayout": { "dotsSource": "state.dpiStages", "selectMutation": "set-dpi-stage", "setMutation": ["set-dpi-value", "set-dpi-value-extended"], "valueSource": "state.dpiStages", "range": { "min": 50, "max": 30000, "step": 50 }, "selectParam": "stage", "stageParam": "stage", "valueParam": "dpi" }, "stateMapping": { "dpiStages": "dpiStages" } } },
    { "id": "pointer-speed", "control": "Number", "labelKey": "plugin.label.capability.pointer-speed", "readOnly": false, "placements": [{ "region": "control", "group": "performance", "order": 15, "span": 1, "icon": "gauge" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.pointerSpeed.speedRaw", "mutation": "set-pointer-speed", "param": "speed", "editor": "modal-number", "range": { "min": 46, "max": 511, "step": 1 }, "labelKey": "plugin.label.capability.pointer-speed" }] } },
    { "id": "polling-rate", "control": "Select", "labelKey": "capability.polling-rate", "readOnly": false, "placements": [{ "region": "control", "group": "polling", "order": 20, "span": 1, "icon": "wave" }], "metadata": { "fields": [{ "id": "value", "source": "state.pollingRate", "mutation": ["set-polling-rate", "set-polling-rate-extended"], "param": "rate", "editor": "modal-select", "optionSource": "state.supportedPollingRates", "format": "hertz", "labelKey": "capability.polling-rate" }], "stateMapping": { "pollingRate": "pollingRateHz", "supportedPollingRates": "supportedPollingRatesHz" } } },
    { "id": "mouse-lighting", "control": "LightingZone", "labelKey": "plugin.label.capability.mouse-lighting", "readOnly": false, "placements": [{ "region": "control", "group": "lighting", "order": 30, "span": 1, "icon": "lightbulb" }, { "region": "status", "order": 20, "span": 1, "icon": "lightbulb" }], "metadata": { "zones": [{ "id": "mouse", "labelKey": "plugin.label.capability.mouse-lighting", "fields": [{ "id": "enabled", "source": "capabilities.mouseLighting.enabled", "mutation": "set-mouse-lighting", "param": "enabled", "editor": "inline-toggle", "switch": { "source": "capabilities.mouseLighting.enabled", "offValue": false }, "labelKey": "dashboard.status" }, { "id": "effect", "source": "capabilities.mouseLighting.effect", "mutation": "set-mouse-lighting", "param": "effect", "editor": "modal-select", "labelKey": "receiverLighting.field.effect", "options": [{ "value": 0, "labelKey": "lighting.off" }, { "value": 1, "labelKey": "lighting.fixed" }, { "value": 3, "labelKey": "lighting.cycle" }, { "value": 4, "labelKey": "lighting.wave" }, { "value": 5, "labelKey": "lighting.starlight" }, { "value": 10, "labelKey": "lighting.breathing" }, { "value": 11, "labelKey": "lighting.ripple" }, { "value": 12, "labelKey": "lighting.custom" }] }, { "id": "speed", "source": "capabilities.mouseLighting.speed", "mutation": "set-mouse-lighting", "param": "speed", "editor": "modal-range", "range": { "min": 0, "max": 255, "step": 1 }, "labelKey": "receiverLighting.field.speed" }, { "id": "brightness", "source": "capabilities.mouseLighting.brightness", "mutation": "set-mouse-lighting", "param": "brightness", "editor": "modal-range", "range": { "min": 0, "max": 100, "step": 1 }, "labelKey": "receiverLighting.field.brightness" }, { "id": "color", "source": "capabilities.mouseLighting.color", "mutation": "set-mouse-lighting", "param": "color", "editor": "modal-color", "format": "color", "labelKey": "receiverLighting.field.color" }, { "id": "extra-color", "source": "capabilities.mouseLighting.extraColor", "mutation": "set-mouse-lighting", "param": "extraColor", "editor": "modal-color", "format": "color", "labelKey": "lighting.extraColor" }]}], "statusDisplay": { "valueSource": "capabilities.mouseLighting.color", "valueFormat": "color", "onClickField": "color" } } },
    { "id": "device-info", "control": "ReadOnlyValue", "labelKey": "plugin.label.capability.device-info", "readOnly": true, "placements": [{ "region": "details", "order": 10, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities", "editor": "static-readonly", "labelKey": "plugin.label.capability.device-info" }] } },
    { "id": "feature-index", "control": "ReadOnlyValue", "labelKey": "plugin.label.capability.feature-index", "readOnly": true, "placements": [{ "region": "details", "order": 20, "span": 1, "icon": "info" }], "metadata": { "fields": [{ "id": "value", "source": "capabilities.featureIndex", "editor": "static-readonly", "labelKey": "plugin.label.capability.feature-index" }] } }
  ],
  "writesEnabled": true
}
