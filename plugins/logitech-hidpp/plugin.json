            "labelKey": "plugin.label.capability.dpi-capability"
          }
        ]
      }
    },
    {
      "id": "dpi-list",
      "control": "ReadOnlyValue",
      "labelKey": "plugin.label.capability.dpi-list",
      "readOnly": true,
      "placements": [
        {
          "region": "details",
          "order": 26,
          "span": 1,
          "icon": "list"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
