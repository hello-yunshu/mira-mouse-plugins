{
  "schemaVersion": 1,
  "pluginId": "mira.logitech-hidpp",
  "name": "Logitech HID++",
  "version": "0.9.2",
  "pluginApi": ">=1.1.0, <2.0.0",
  "publisherKeyId": null,
  "evidence": "hardware-verified",
  "permissions": [
    {
      "kind": "hid",
      "report_types": [
        "feature",
        "input",
        "output"
      ],
      "max_report_length": 20,
      "max_reports_per_second": 60
    }
  ],
  "runtime": {
    "wakeRecovery": {
      "activitySource": "system-pointer",
      "componentId": "mouse",
      "connections": [
        "wireless"
      ]
    },
    "inventory": {
      "workflows": [
        "hidpp2-device-read"
      ],
      "refresh": "on-open",
      "cacheTtlSeconds": 300
    }
  },
  "capabilities": [
    {
      "id": "battery",
      "control": "ReadOnlyValue",
      "labelKey": "capability.battery",
      "readOnly": true,
      "placements": [
        {
          "region": "hero",
          "order": 10,
          "span": 1,
          "icon": "battery"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
            "source": "battery",
            "editor": "static-readonly",
            "format": "percent",
            "labelKey": "capability.battery"
          }
        ],
        "batteryHistory": {
          "validConnections": [
            "wireless",
            "usb"
          ]
        }
      }
    },
    {
      "id": "control-mode",
      "control": "Segmented",
      "labelKey": "plugin.label.capability.control-mode",
      "readOnly": false,
      "placements": [
        {
          "region": "control",
          "group": "configuration",
          "order": 5,
          "span": 1,
          "icon": "settings"
        },
        {
          "region": "status",
          "order": 10,
          "span": 1,
          "icon": "settings"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
            "source": "capabilities.controlMode.mode",
            "mutation": "set-control-mode",
            "param": "mode",
            "editor": "inline-segmented",
            "labelKey": "plugin.label.capability.control-mode",
            "options": [
              {
                "value": 1,
                "labelKey": "controlMode.onboard"
              },
              {
                "value": 2,
                "labelKey": "controlMode.software"
              }
            ]
          }
        ],
        "statusDisplay": {
          "valueSource": "capabilities.controlMode.mode",
          "valueOptions": [
            {
              "value": 1,
              "labelKey": "controlMode.onboard"
            },
            {
              "value": 2,
              "labelKey": "controlMode.software"
            }
          ],
          "onClickField": "value"
        }
      }
    },
    {
      "id": "profile-mgmt-current",
      "control": "Number",
      "labelKey": "plugin.label.capability.profile-mgmt-current",
      "readOnly": false,
      "probe": {
        "output": "featureIndexProfileManagement",
        "field": "featureIndex"
      },
      "placements": [
        {
          "region": "control",
          "group": "configuration",
          "order": 6,
          "span": 1,
          "icon": "profile"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
            "source": "capabilities.profileMgmtCurrent.profileIndex",
            "mutation": "set-profile-mgmt-current",
            "param": "profileIndex",
            "editor": "modal-number",
            "range": {
              "min": 0,
              "max": 15,
              "step": 1
            },
            "rangeSource": "capabilities.profileMgmtInfo.maxProfileCount",
            "rangeMaxOffset": -1,
            "labelKey": "plugin.label.capability.profile-mgmt-current"
          }
        ]
      }
    },
    {
      "id": "dpi",
      "control": "DpiStages",
      "labelKey": "capability.dpi",
      "readOnly": false,
      "placements": [
        {
          "region": "control",
          "group": "performance",
          "order": 10,
          "span": 1,
          "icon": "gauge"
        }
      ],
      "metadata": {
        "stageLayout": {
          "dotsSource": "state.dpiStages",
          "selectMutation": "set-dpi-stage",
          "setMutation": [
            "set-dpi-value",
            "set-dpi-value-extended"
          ],
          "valueSource": "state.dpiStages",
          "range": {
            "min": 50,
            "max": 30000,
            "step": 50
          },
          "selectParam": "stage",
          "stageParam": "stage",
          "valueParam": "dpi"
        },
        "stateMapping": {
          "dpiStages": "dpiStages"
        }
      }
    },
    {
      "id": "pointer-speed",
      "control": "Number",
      "labelKey": "plugin.label.capability.pointer-speed",
      "readOnly": false,
      "probe": {
        "output": "featureIndexPointerSpeed",
        "field": "featureIndex"
      },
      "placements": [
        {
          "region": "control",
          "group": "performance",
          "order": 15,
          "span": 1,
          "icon": "gauge"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
            "source": "capabilities.pointerSpeed.speedRaw",
            "mutation": "set-pointer-speed",
            "param": "speed",
            "editor": "modal-number",
            "range": {
              "min": 46,
              "max": 511,
              "step": 1
            },
            "labelKey": "plugin.label.capability.pointer-speed"
          }
        ]
      }
    },
    {
      "id": "polling-rate",
      "control": "Select",
      "labelKey": "capability.polling-rate",
      "readOnly": false,
      "placements": [
        {
          "region": "control",
          "group": "polling",
          "order": 20,
          "span": 1,
          "icon": "wave"
        }
      ],
      "metadata": {
        "fields": [
          {
            "id": "value",
            "source": "state.pollingRate",
            "mutation": [
              "set-polling-rate",
              "set-polling-rate-extended"
            ],
            "param": "rate",
            "editor": "modal-select",
            "optionSource": "state.supportedPollingRates",
            "format": "hertz",
            "labelKey": "capability.polling-rate"
          }
        ],
        "stateMapping": {
          "pollingRate": "pollingRateHz",
          "supportedPollingRates": "supportedPollingRatesHz"
        },
        "summary": [
          {
            "labelKey": "plugin.label.capability.control-mode",
            "source": "capabilities.controlMode.mode",
            "options": [
              {
                "value": 1,
                "labelKey": "controlMode.onboard"
              },
              {
                "value": 2,
                "labelKey": "controlMode.software"
              }
            ]
          },
          {
            "labelKey": "plugin.label.capability.profile-mgmt-current",
            "source": "capabilities.profileMgmtCurrent.profileIndex"
          }
        ]
      }
    },
    {
      "id": "mouse-lighting",
      "control": "LightingZone",
      "labelKey": "plugin.label.capability.mouse-lighting",
      "readOnly": false,
      "placements": [
        {
          "region": "control",
          "group": "lighting",
          "order": 30,
          "span": 1,
          "icon": "lightbulb"
        },
        {
          "region": "status",
          "order": 20,
          "span": 1,
          "icon": "lightbulb"
        }
      ],
      "metadata": {
        "accentSource": "capabilities.mouseLighting.color",
        "zones": [
          {
            "id": "mouse",
            "labelKey": "plugin.label.capability.mouse-lighting",
            "fields": [
              {
                "id": "enabled",
                "source": "capabilities.mouseLighting.enabled",
                "mutation": "set-mouse-lighting",
                "param": "enabled",
                "editor": "inline-toggle",
                "switch": {
                  "source": "capabilities.mouseLighting.enabled",
                  "offValue": false
                },
                "labelKey": "dashboard.status",
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              },
              {
                "id": "effect",
                "source": "capabilities.mouseLighting.effect",
                "mutation": "set-mouse-lighting",
                "param": "effect",
                "editor": "modal-select",
                "labelKey": "receiverLighting.field.effect",
                "labelSource": "capabilities.mouseLighting.effectName",
                "options": [
                  {
                    "value": 0,
                    "labelKey": "lighting.off"
                  },
                  {
                    "value": 1,
                    "labelKey": "lighting.fixed"
                  },
                  {
                    "value": 3,
                    "labelKey": "lighting.cycle"
                  },
                  {
                    "value": 4,
                    "labelKey": "lighting.wave"
                  },
                  {
                    "value": 5,
                    "labelKey": "lighting.starlight"
                  },
                  {
                    "value": 10,
                    "labelKey": "lighting.breathing"
                  },
                  {
                    "value": 11,
                    "labelKey": "lighting.ripple"
                  },
                  {
                    "value": 12,
                    "labelKey": "lighting.custom"
                  }
                ],
                "optionSource": "capabilities.mouseLighting.supportedEffects",
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              },
              {
                "id": "speed",
                "source": "capabilities.mouseLighting.speed",
                "mutation": "set-mouse-lighting",
                "param": "speed",
                "editor": "modal-range",
                "range": {
                  "min": 0,
                  "max": 255,
                  "step": 1
                },
                "labelKey": "receiverLighting.field.speed",
                "labelSource": "capabilities.mouseLighting.speedLabel",
                "visibleWhen": {
                  "path": "capabilities.mouseLighting.speed"
                },
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              },
              {
                "id": "brightness",
                "source": "capabilities.mouseLighting.brightness",
                "mutation": "set-mouse-lighting",
                "param": "brightness",
                "editor": "modal-range",
                "range": {
                  "min": 0,
                  "max": 100,
                  "step": 1
                },
                "labelKey": "receiverLighting.field.brightness",
                "labelSource": "capabilities.mouseLighting.brightnessLabel",
                "visibleWhen": {
                  "path": "capabilities.mouseLighting.brightness"
                },
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              },
              {
                "id": "color",
                "source": "capabilities.mouseLighting.color",
                "mutation": "set-mouse-lighting",
                "param": "color",
                "editor": "modal-color",
                "format": "color",
                "labelKey": "receiverLighting.field.color",
                "editTitleKey": "dashboard.mouseLightColor",
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              },
              {
                "id": "extra-color",
                "source": "capabilities.mouseLighting.extraColor",
                "mutation": "set-mouse-lighting",
                "param": "extraColor",
                "editor": "modal-color",
                "format": "color",
                "labelKey": "lighting.extraColor",
                "visibleWhen": {
                  "path": "capabilities.mouseLighting.effect",
                  "eq": 5
                },
                "params": {
                  "extraColor": "#000000"
                },
                "paramSources": {
                  "color": "capabilities.mouseLighting.color",
                  "enabled": "capabilities.mouseLighting.enabled",
                  "effect": "capabilities.mouseLighting.effect",
                  "speed": "capabilities.mouseLighting.speed",
                  "brightness": "capabilities.mouseLighting.brightness",
                  "extraColor": "capabilities.mouseLighting.extraColor"
                }
              }
            ]
          }
        ],
        "statusDisplay": {
          "labelKey": "plugin.label.capability.mouse-lighting",
          "valueSource": "capabilities.mouseLighting.effect",
          "valueOptions": [
            {
              "value": 0,
              "labelKey": "lighting.off"
            },
            {
              "value": 1,
              "labelKey": "lighting.on"
            },
            {
              "value": 3,
              "labelKey": "lighting.on"
            },
            {
              "value": 4,
              "labelKey": "lighting.on"
            },
            {
              "value": 5,
              "labelKey": "lighting.on"
            },
            {
              "value": 10,
              "labelKey": "lighting.on"
            },
            {
              "value": 11,
              "labelKey": "lighting.on"
            },
            {
              "value": 12,
              "labelKey": "lighting.on"
            }
          ],
          "onClickField": "color"
        }
      }
    },
    {
      "id": "device-info",
